rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin SDK her zaman bypass eder — bu rules sadece client SDK için.
    //
    // PREMIUM/KREDİ KALDIRILDI: Uygulama tamamen ucretsiz.
    // Eski korumalı alanlar (isPremium / credits / premium*) artik update kuralinda
    // kontrol edilmez. Ancak geriye uyumluluk icin rules hâlâ bu alanlara
    // client tarafindan yanlislikla yazilmasini engeller.
    //
    // İzinli client alanlar: dailyUsage, totalAnalyses, fcmTokens, lastSeen,
    //                        adsWatched, rewardedAdsWatched

    match /users/{userId} {
      // Kullanici kendi doc'unu okuyabilir; admin token her seyi okuyabilir (admin panel).
      allow read: if request.auth != null
        && (request.auth.uid == userId || request.auth.token.admin == true);

      // Yeni kullanici olusturma
      allow create: if request.auth != null && request.auth.uid == userId;

      // Guncelleme — premium/credit alanlarina dokunamaz (geriye uyumluluk)
      allow update: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'isPremium', 'premiumExpiry', 'premiumPackageId', 'credits', 'premiumActivatedAt'
        ]);
    }

    // purchases koleksiyonu artik sadece eski veriler icin (geriye uyumluluk)
    match /purchases/{purchaseId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
